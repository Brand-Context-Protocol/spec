{
      "$schema": "https://json-schema.org/draft/2020-12/schema",
        "$id": "https://schema.brandcontextprotocol.dev/v0.2/representation.json",
          "title": "Brand Context Protocol — representation.md",
            "description": "Schema for BCP v0.2 representation.md daughter files. v0.2 adds never_compare_to and framing_traps to the existing v0.1 fields.",
              "type": "object",
                "properties": {
                    "bcp_version": { "type": "string", "const": "0.2" },
                        "file_type": { "type": "string", "const": "representation" },
                            "parent": { "type": "string" },
                                "last_updated": { "type": "string", "format": "date" },
                                    "preferred_framing": {
                                          "type": "string",
                                                "description": "Prose paragraph (~120 words or less) for consumer agents to paraphrase in open-ended queries."
                                                    },
                                                        "describe_as": {
                                                              "type": "array",
                                                                    "items": { "type": "string" }
                                                                        },
                                                                            "do_not_describe_as": {
                                                                                  "type": "array",
                                                                                        "items": { "type": "string" }
                                                                                            },
                                                                                                "competitive_frame": {
                                                                                                      "type": "array",
                                                                                                            "items": { "type": "string" }
                                                                                                                },
                                                                                                                    "honest_trade_offs": {
                                                                                                                          "type": "array",
                                                                                                                                "items": { "type": "string" }
                                                                                                                                    },
                                                                                                                                        "never_say": {
                                                                                                                                              "type": "array",
                                                                                                                                                    "items": { "type": "string" },
                                                                                                                                                          "description": "Binding list. Consumers MUST NOT produce these strings or close paraphrases."
                                                                                                                                                              },
                                                                                                                                                                  "never_compare_to": {
                                                                                                                                                                        "type": "array",
                                                                                                                                                                              "items": { "type": "string" },
                                                                                                                                                                                    "description": "Binding list of entities the brand refuses to be analogized to. Distinct from competitors. Consumers MUST NOT generate analogies of the form 'like X' where X is on this list."
                                                                                                                                                                                        },
                                                                                                                                                                                            "framing_traps": {
                                                                                                                                                                                                  "type": "array",
                                                                                                                                                                                                        "items": {
                                                                                                                                                                                                                "type": "object",
                                                                                                                                                                                                                        "properties": {
                                                                                                                                                                                                                                  "trap": {
                                                                                                                                                                                                                                              "type": "string",
                                                                                                                                                                                                                                                          "description": "The third-party framing the brand rejects."
                                                                                                                                                                                                                                                                    },
                                                                                                                                                                                                                                                                              "preferred_reframe": {
                                                                                                                                                                                                                                                                                          "type": "string",
                                                                                                                                                                                                                                                                                                      "description": "How the brand prefers to be described instead."
                                                                                                                                                                                                                                                                                                                },
                                                                                                                                                                                                                                                                                                                          "rationale": {
                                                                                                                                                                                                                                                                                                                                      "type": "string",
                                                                                                                                                                                                                                                                                                                                                  "description": "Optional note explaining why this framing is rejected."
                                                                                                                                                                                                                                                                                                                                                            }
                                                                                                                                                                                                                                                                                                                                                                    },
                                                                                                                                                                                                                                                                                                                                                                            "required": ["trap"]
                                                                                                                                                                                                                                                                                                                                                                                  },
                                                                                                                                                                                                                                                                                                                                                                                        "description": "Third-party framings that are technically defensible but the brand rejects (e.g., 'the Uber of X', 'a pivot from Y'). Consumers SHOULD NOT use these framings and SHOULD substitute the preferred_reframe when one is provided."
                                                                                                                                                                                                                                                                                                                                                                                            },
                                                                                                                                                                                                                                                                                                                                                                                                "extensions": {
                                                                                                                                                                                                                                                                                                                                                                                                      "type": "object",
                                                                                                                                                                                                                                                                                                                                                                                                            "additionalProperties": true
                                                                                                                                                                                                                                                                                                                                                                                                                }
                                                                                                                                                                                                                                                                                                                                                                                                                  },
                                                                                                                                                                                                                                                                                                                                                                                                                    "required": ["bcp_version", "file_type", "parent", "last_updated"]
                                                                                                                                                                                                                                                                                                                                                                                                                    }
}